# ============================================================
# VEGA AI Assistant — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control.
# ============================================================

# --- Google Gemini AI ---
GOOGLE_AI_API_KEY=

# --- Picovoice (Wake Word Detection) ---
PICOVOICE_ACCESS_KEY=

# --- OpenWeatherMap ---
OPENWEATHER_API_KEY=

# --- GNews ---
GNEWS_API_KEY=

# --- Gmail (SMTP) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Logging ---
LOG_LEVEL=INFO
